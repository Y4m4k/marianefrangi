---
const amazonMainLink = "https://www.amazon.com/stores/Mariane-Frangi/author/B0FT1XPKV6";
const bookingEmail = "mailto:hello@marianefrangi.com?subject=School%20or%20Library%20Read-Aloud%20Request";

const featuredBooks = [
  {
    image: "/images/do-you-want-to-read-me.PNG",
    alt: "Do You Want to Read Me book cover"
  },
  {
    image: "/images/why-books-dread-summer-vacation.PNG",
    alt: "Why Books Dread Summer Vacation book cover"
  },
  {
    image: "/images/why-books-love-winter.PNG",
    alt: "Why Books Love Winter book cover"
  }
];
---

<section class="hero wrap" id="top">
  <div class="hero-cover hero-slideshow" aria-label="Featured books by Mariane Frangi">
    <div class="hero-track">
      {featuredBooks.map((book) => (
        <img
          src={book.image}
          alt={book.alt}
        />
      ))}
    </div>
  </div>

  <div class="hero-copy">
    <p class="eyebrow">Children's Book Author</p>
    <h1>Funny books kids actually want to read.</h1>
    <p class="hero-subtitle">
      Interactive children’s books that make kids laugh, read, and learn —
      perfect for classrooms, libraries, bedtime, and silly read-aloud moments.
    </p>

    <div class="button-row">
      <a class="button filled" href={amazonMainLink} target="_blank" rel="noopener">Shop the Books</a>
      <a class="button outline" href={bookingEmail}>Book a Reading</a>
    </div>
  </div>
</section>
